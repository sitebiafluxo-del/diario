{
  "appId": "com.sitebiafluxo.diario",
  "appName": "Diario Bia",
  "webDir": "dist",
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "server": {
    "allowNavigation": [
      "*.pollinations.ai",
      "*.groq.com",
      "*.openai.com",
      "*.vercel.app",
      "*.supabase.co",
      "*.googleapis.com"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
