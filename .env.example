# ─── SUPABASE ────────────────────────────────────────────────
# Acesse: https://supabase.com → seu projeto → Settings → API
# Estas variáveis VITE_ ficam no bundle do browser (a anon key é pública por design)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── OPENAI — SERVER-SIDE (Vercel) ───────────────────────────
# Configure em: Vercel → Settings → Environment Variables
# SEM o prefixo VITE_ para NÃO vazar no bundle do browser
# Usado para: transcrição de áudio (Whisper) e geração de papéis (DALL-E 3)
OPENAI_API_KEY=sk-...

# ─── GOOGLE GEMINI — SERVER-SIDE (Vercel) ────────────────────
# Configure em: Vercel → Settings → Environment Variables
# SEM o prefixo VITE_ para NÃO vazar no bundle do browser
# Usado para: geração de temas visuais com IA
GEMINI_API_KEY=AIza...

# ─── DEV LOCAL SOMENTE ───────────────────────────────────────
# Estas variáveis só são necessárias em desenvolvimento local.
# Em produção (Vercel), as chamadas passam pelo proxy em api/ e
# usam OPENAI_API_KEY / GEMINI_API_KEY (server-side, acima).
# NÃO configure estas variáveis no Vercel.
VITE_WHISPER_API_KEY=sk-...
VITE_GEMINI_API_KEY=AIza...
VITE_WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
