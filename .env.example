# ─── SUPABASE ────────────────────────────────────────────────
# Acesse: https://supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── GOOGLE GEMINI ───────────────────────────────────────────
# Acesse: https://aistudio.google.com → Get API Key (gratuito)
# Usado para: geração de temas visuais e papel de carta com IA
VITE_GEMINI_API_KEY=AIza...

# ─── OPENAI / WHISPER ────────────────────────────────────────
# Acesse: https://platform.openai.com → API Keys (pago por uso)
# Usado para: transcrição automática de áudios gravados
# Se não configurar, o app usa reconhecimento de voz do navegador como fallback
VITE_WHISPER_API_KEY=sk-...
VITE_WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
